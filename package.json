{
  "name": "boss-auto-greeter",
  "version": "0.1.0",
  "description": "Windows-first local Electron app skeleton for BOSS Auto Greeter",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "check": "node scripts/check-syntax.js",
    "check:core": "node --check electron/main.js && node --check electron/preload.js && node --check src/renderer/app.js",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.openclaw.bossautogreeter",
    "productName": "BOSS 求职助手",
    "files": [
      "electron/**/*",
      "src/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/mcp-boss",
        "to": "mcp-boss",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    }
  },
  "keywords": [
    "electron",
    "boss",
    "siliconflow"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  }
}
